# RepairoX environment variables
# Copy this file to ".env" and fill in real values. NEVER commit .env to git.

SECRET_KEY=django-insecure-dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=

